---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const currentYear = new Date().getFullYear();
const siteUrl = "https://takehomepay.nz";
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1e3a5f" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_NZ" />
    <meta property="og:site_name" content="TakeHomePay.nz" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Header -->
    <header class="bg-primary text-white shadow-lg">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
            <img src="/favicon.svg" alt="NZ $" class="w-8 h-8" />
            <span class="text-xl font-bold">TakeHomePay.nz</span>
          </a>
          <nav class="hidden sm:flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Calculator</a>
            <a href="/faq/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">FAQ</a>
            <a href="/legal/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Legal</a>
            <a href="/privacy/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Privacy</a>
          </nav>
          <!-- Mobile menu button -->
          <div class="sm:hidden">
            <details class="relative">
              <summary class="list-none cursor-pointer p-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </summary>
              <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg py-2 z-50">
                <a href="/" class="block px-4 py-2 text-sm text-text hover:bg-surface-alt">Calculator</a>
                <a href="/faq/" class="block px-4 py-2 text-sm text-text hover:bg-surface-alt">FAQ</a>
                <a href="/legal/" class="block px-4 py-2 text-sm text-text hover:bg-surface-alt">Legal</a>
                <a href="/privacy/" class="block px-4 py-2 text-sm text-text hover:bg-surface-alt">Privacy</a>
              </div>
            </details>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-dark text-white/80 mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">TakeHomePay.nz</h3>
            <p class="text-sm leading-relaxed">
              Free New Zealand salary calculator for the 2025-2026 tax year. Calculate your PAYE income tax, ACC levy, KiwiSaver contributions, and student loan repayments.
            </p>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-white transition-colors">Salary Calculator</a></li>
              <li><a href="/faq/" class="hover:text-white transition-colors">Frequently Asked Questions</a></li>
              <li><a href="/legal/" class="hover:text-white transition-colors">Legal Disclaimer</a></li>
              <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Useful Resources</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://www.ird.govt.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Inland Revenue (IRD)</a></li>
              <li><a href="https://www.acc.co.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">ACC New Zealand</a></li>
              <li><a href="https://www.kiwisaver.govt.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">KiwiSaver</a></li>
              <li><a href="https://www.employment.govt.nz/hours-and-wages/pay/minimum-wage/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Minimum Wage NZ</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/20 mt-8 pt-8 text-center text-sm">
          <p>&copy; {currentYear} TakeHomePay.nz. All rights reserved. This calculator is for informational purposes only.</p>
          <p class="mt-1">Tax rates are based on the New Zealand 2025-2026 tax year (1 April 2025 - 31 March 2026).</p>
        </div>
      </div>
    </footer>
  </body>
</html>
