---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const currentYear = new Date().getFullYear();
const siteUrl = "https://takehomepay.nz";
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1e3a5f" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_NZ" />
    <meta property="og:site_name" content="TakeHomePay.nz" />
    <meta name="author" content="Mottalib Radif" />
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Take Home Pay New Zealand",
      "url": "https://takehomepay.nz",
      "logo": "https://takehomepay.nz/favicon.svg",
      "founder": {
        "@type": "Person",
        "name": "Mottalib Radif"
      }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Mottalib Radif",
      "jobTitle": "Personal Finance & Taxation Expert",
      "description": "MBA INSEAD graduate, passionate about New Zealand personal finance. Specialised in PAYE, KiwiSaver, and ACC levy analysis.",
      "alumniOf": { "@type": "EducationalOrganization", "name": "INSEAD" },
      "image": "https://takehomepay.nz/team/mottalib-radif.jpg",
      "url": "https://takehomepay.nz/about/"
    })} />

    <!-- Plausible Analytics -->
    <script defer data-domain="takehomepay.nz" src="https://plausible.io/js/script.js"></script>

    <!-- Google Analytics 4 — replace G-XXXXXXXXXX with real ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-blue-700 focus:rounded-lg focus:shadow-lg focus:ring-2 focus:ring-blue-500">Skip to content</a>
    <!-- Header -->
    <header class="bg-primary text-white shadow-lg">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
            <img src="/favicon.svg" alt="NZ $" class="w-8 h-8" />
            <span class="text-xl font-bold">TakeHomePay.nz</span>
          </a>
          <nav class="hidden sm:flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Calculator</a>
            <a href="/guides/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Guides</a>
            <a href="/faq/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">FAQ</a>
            <a href="/legal/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Legal</a>
            <a href="/privacy/" class="text-sm font-medium text-white/90 hover:text-white transition-colors">Privacy</a>
          </nav>
          <!-- Mobile hamburger menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="sm:hidden relative w-8 h-8 flex flex-col items-center justify-center gap-1.5 cursor-pointer bg-transparent border-none"
            aria-label="Toggle navigation menu"
            aria-expanded="false"
            aria-controls="mobile-menu-panel"
          >
            <span class="hamburger-line block w-6 h-0.5 bg-white rounded transition-all duration-300 origin-center"></span>
            <span class="hamburger-line block w-6 h-0.5 bg-white rounded transition-all duration-300 origin-center"></span>
            <span class="hamburger-line block w-6 h-0.5 bg-white rounded transition-all duration-300 origin-center"></span>
          </button>
        </div>
      </div>
      <!-- Collapsible mobile nav panel -->
      <div
        id="mobile-menu-panel"
        class="sm:hidden hidden border-t border-white/20"
      >
        <nav class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-3">
          <a href="/" class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">Calculator</a>
          <a href="/guides/" class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">Guides</a>
          <a href="/faq/" class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">FAQ</a>
          <a href="/legal/" class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">Legal</a>
          <a href="/privacy/" class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">Privacy</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-primary-dark text-white/80 mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">TakeHomePay.nz</h3>
            <p class="text-sm leading-relaxed">
              Free New Zealand salary calculator for the 2025-2026 tax year. Calculate your PAYE income tax, ACC levy, KiwiSaver contributions, and student loan repayments.
            </p>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="hover:text-white transition-colors">Salary Calculator</a></li>
              <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
              <li><a href="/faq/" class="hover:text-white transition-colors">Frequently Asked Questions</a></li>
              <li><a href="/legal/" class="hover:text-white transition-colors">Legal Disclaimer</a></li>
              <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg mb-3">Useful Resources</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://www.ird.govt.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Inland Revenue (IRD)</a></li>
              <li><a href="https://www.acc.co.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">ACC New Zealand</a></li>
              <li><a href="https://www.kiwisaver.govt.nz/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">KiwiSaver</a></li>
              <li><a href="https://www.employment.govt.nz/hours-and-wages/pay/minimum-wage/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Minimum Wage NZ</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/20 mt-8 pt-8 text-center text-sm">
          <p>By <a href="/about/" class="text-white hover:underline">Mottalib Radif</a>, MBA INSEAD</p>
          <p class="mt-1">&copy; {currentYear} TakeHomePay.nz. All rights reserved. This calculator is for informational purposes only.</p>
          <p class="mt-1">Tax rates are based on the New Zealand 2025-2026 tax year (1 April 2025 - 31 March 2026).</p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var panel = document.getElementById('mobile-menu-panel');
        if (!btn || !panel) return;

        btn.addEventListener('click', function() {
          var isOpen = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!isOpen));
          panel.classList.toggle('hidden');
          // Animate hamburger lines into X
          var lines = btn.querySelectorAll('.hamburger-line');
          if (!isOpen) {
            lines[0].style.transform = 'translateY(8px) rotate(45deg)';
            lines[1].style.opacity = '0';
            lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
          } else {
            lines[0].style.transform = '';
            lines[1].style.opacity = '';
            lines[2].style.transform = '';
          }
        });
      })();
    </script>
  </body>
</html>
