---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found - TakeHomePay.nz" description="The page you're looking for doesn't exist or has been moved.">
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="text-6xl font-bold text-gray-300 mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-gray-800 mb-4">Page Not Found</h2>
    <p class="text-gray-600 mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Back to Home</a>
  </div>
</Layout>
