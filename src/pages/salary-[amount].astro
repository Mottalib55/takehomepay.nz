---
import Layout from "../layouts/Layout.astro";
import SalaryCalculator from "../components/SalaryCalculator";
import { salaries, type SalaryEntry } from "../lib/salaries-data";
import { calculateSalary } from "../lib/engine";
import type { KiwiSaverRate } from "../lib/tax-rates-2026";
import {
  fmtNZD,
  fmtNZD2,
  fmtPct,
  classifyBand,
  getPAYEBreakdown,
  getBandContext,
  getHowTaxWorks,
  getBudgetBreakdown,
  getKiwiSaverDeepDive,
  getStudentLoanSection,
  getTaxTips,
  getCareerContext,
  getUniqueComparisons,
  buildFaqs,
} from "../lib/salary-content";
import "../styles/global.css";

export function getStaticPaths() {
  return salaries.map((entry) => ({
    params: { amount: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: SalaryEntry;
}

const { entry } = Astro.props;

// Calculate base result (3% KiwiSaver, no student loan, resident)
const baseResult = calculateSalary({
  annualGross: entry.gross,
  kiwiSaverRate: 0.03,
  hasStudentLoan: false,
  isResident: true,
});

// KiwiSaver comparison rates
const kiwiSaverRates: KiwiSaverRate[] = [0.03, 0.04, 0.06, 0.08, 0.10];
const kiwiSaverComparison = kiwiSaverRates.map((rate) => {
  const result = calculateSalary({
    annualGross: entry.gross,
    kiwiSaverRate: rate,
    hasStudentLoan: false,
    isResident: true,
  });
  return {
    rate,
    rateLabel: `${(rate * 100).toFixed(0)}%`,
    employeeContribution: result.kiwiSaverEmployee,
    employerContribution: result.kiwiSaverEmployer,
    totalDeductions: result.totalDeductions,
    netAnnual: result.netAnnual,
    netMonthly: result.netMonthly,
    netFortnightly: result.netFortnightly,
    netWeekly: result.netWeekly,
  };
});

// Content helpers
const bracketRows = getPAYEBreakdown(entry.gross);
const bandContext = getBandContext(entry.gross, baseResult);
const howTaxWorks = getHowTaxWorks(entry.gross, baseResult);
const budgetRows = getBudgetBreakdown(baseResult.netMonthly);
const kiwiSaverDeepDive = getKiwiSaverDeepDive(entry.gross, baseResult);
const studentLoanSection = getStudentLoanSection(entry.gross);
const taxTips = getTaxTips(entry.gross, baseResult);
const careerContext = getCareerContext(entry.gross);
const comparisons = getUniqueComparisons(entry.gross, baseResult);
const faqs = buildFaqs(entry.gross, baseResult);

const pageTitle = `${entry.grossFormatted} Salary in New Zealand - Take Home Pay 2026`;
const pageDescription = `Calculate your take home pay on a ${entry.grossFormatted} salary in New Zealand. See PAYE tax (${fmtNZD(baseResult.paye)}), ACC levy, KiwiSaver deductions, and net income (${fmtNZD(baseResult.netAnnual)}) for the 2025-2026 tax year.`;

// Cross-link data
const otherSalaries = salaries.filter((s) => s.slug !== entry.slug);

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://takehomepay.nz/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `${entry.grossFormatted} Salary`,
      item: `https://takehomepay.nz/salary-${entry.slug}/`,
    },
  ],
};

// Schema.org FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

// Schema.org Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: pageTitle,
  description: pageDescription,
  author: {
    "@type": "Person",
    name: "Mottalib Radif",
    jobTitle: "Personal Finance & Taxation Expert",
    description: "MBA INSEAD graduate specialising in New Zealand personal finance, PAYE, KiwiSaver, and ACC levy analysis.",
    alumniOf: { "@type": "EducationalOrganization", name: "INSEAD" },
    url: "https://takehomepay.nz/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "TakeHomePay.nz",
    url: "https://takehomepay.nz",
  },
  datePublished: "2025-04-01",
  dateModified: new Date().toISOString().split("T")[0],
  mainEntityOfPage: `https://takehomepay.nz/salary-${entry.slug}/`,
};

const hourlyRate = (entry.gross / (40 * 52)).toFixed(2);
---

<Layout title={pageTitle} description={pageDescription} canonical={`/salary-${entry.slug}/`}>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary via-primary-light to-accent py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/80">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="flex items-center gap-2">
            <span>/</span>
            <span class="text-white font-medium">{entry.grossFormatted} Salary</span>
          </li>
        </ol>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 text-white">
        {entry.grossFormatted} Salary in New Zealand
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-3xl">
        Complete take home pay breakdown for the 2025-2026 tax year including PAYE, ACC, KiwiSaver, and student loan calculations.
      </p>
      <p class="text-sm text-white/70 mt-3">
        Reviewed by <a href="/about/" class="underline hover:text-white">Mottalib Radif MBA INSEAD</a> &mdash; Personal Finance & Taxation Expert
      </p>
    </div>
  </section>

  <!-- Stat Cards -->
  <section class="py-8 sm:py-10 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
        <!-- Gross -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-5 text-center">
          <p class="text-xs sm:text-sm font-medium text-text-muted mb-1">Gross Annual</p>
          <p class="text-2xl sm:text-3xl font-bold text-primary">{entry.grossFormatted}</p>
          <p class="text-xs text-text-muted mt-1">${hourlyRate}/hr</p>
        </div>

        <!-- PAYE -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-5 text-center">
          <p class="text-xs sm:text-sm font-medium text-text-muted mb-1">PAYE Tax</p>
          <p class="text-2xl sm:text-3xl font-bold text-secondary">{fmtNZD(baseResult.paye)}</p>
          <p class="text-xs text-text-muted mt-1">Effective {fmtPct(baseResult.paye / entry.gross)}</p>
        </div>

        <!-- ACC -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-5 text-center">
          <p class="text-xs sm:text-sm font-medium text-text-muted mb-1">ACC Levy</p>
          <p class="text-2xl sm:text-3xl font-bold text-secondary">{fmtNZD(baseResult.accLevy)}</p>
          <p class="text-xs text-text-muted mt-1">1.60% of gross</p>
        </div>

        <!-- Net -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-5 text-center">
          <p class="text-xs sm:text-sm font-medium text-text-muted mb-1">Take Home Pay</p>
          <p class="text-2xl sm:text-3xl font-bold text-green-600">{fmtNZD(baseResult.netAnnual)}</p>
          <p class="text-xs text-text-muted mt-1">{fmtNZD2(baseResult.netFortnightly)}/fortnight</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini Calculator -->
  <section class="py-10 sm:py-14 bg-surface" id="calculator">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2 text-center">
        Calculate Your {entry.grossFormatted} Take Home Pay
      </h2>
      <p class="text-text-muted text-center mb-8">
        Adjust KiwiSaver rate, student loan, and residency settings to see your personalised breakdown.
      </p>
      <SalaryCalculator client:idle />
    </div>
  </section>

  <!-- Tax Breakdown Table -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          Detailed {entry.grossFormatted} Salary Breakdown
        </h2>
        <div class="bg-surface-alt rounded-xl p-6 space-y-3">
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">Gross Annual Salary</span>
            <span class="font-semibold">{entry.grossFormatted}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">PAYE Income Tax</span>
            <span class="font-semibold text-secondary">-{fmtNZD2(baseResult.paye)}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">ACC Earner's Levy (1.60%)</span>
            <span class="font-semibold text-secondary">-{fmtNZD2(baseResult.accLevy)}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">KiwiSaver Employee (3%)</span>
            <span class="font-semibold text-secondary">-{fmtNZD2(baseResult.kiwiSaverEmployee)}</span>
          </div>
          {baseResult.ietc > 0 && (
            <div class="flex justify-between border-b border-border pb-2">
              <span class="text-text-muted">IETC Credit</span>
              <span class="font-semibold text-green-600">+{fmtNZD2(baseResult.ietc)}</span>
            </div>
          )}
          <div class="flex justify-between pt-2">
            <span class="font-bold text-primary">Annual Take Home Pay</span>
            <span class="font-bold text-primary text-lg">{fmtNZD2(baseResult.netAnnual)}</span>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6">
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Weekly</p>
            <p class="text-lg font-bold text-primary">{fmtNZD2(baseResult.netWeekly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Fortnightly</p>
            <p class="text-lg font-bold text-primary">{fmtNZD2(baseResult.netFortnightly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Monthly</p>
            <p class="text-lg font-bold text-primary">{fmtNZD2(baseResult.netMonthly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Annual</p>
            <p class="text-lg font-bold text-primary">{fmtNZD2(baseResult.netAnnual)}</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- Band Context - unique paragraph per salary level -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          About a {entry.grossFormatted} Salary in New Zealand
        </h2>
        <p class="text-text leading-relaxed">{bandContext}</p>
      </article>
    </div>
  </section>

  <!-- Salary Comparisons -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          How {entry.grossFormatted} Compares to Other Salary Levels
        </h2>
        <p class="text-text leading-relaxed">{comparisons.vsLower}</p>
        <p class="text-text leading-relaxed mt-4">{comparisons.vsHigher}</p>
        <p class="text-text leading-relaxed mt-4">{comparisons.raiseScenario}</p>
        <p class="text-text leading-relaxed mt-4">{comparisons.taxBreakdownPct}</p>
        <p class="text-text leading-relaxed mt-4">{comparisons.financialContext}</p>
      </article>
    </div>
  </section>

  <!-- How NZ Tax Works -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          How New Zealand Tax Works on {entry.grossFormatted}
        </h2>
        <p class="text-text leading-relaxed">{howTaxWorks}</p>

        <!-- PAYE Bracket Table -->
        <h3 class="text-xl font-bold text-primary mt-8 mb-3">
          PAYE Tax Bracket Breakdown
        </h3>
        <div class="overflow-x-auto">
          <table class="w-full bg-white rounded-xl shadow-lg border border-border text-sm">
            <thead>
              <tr class="bg-primary text-white">
                <th class="px-4 py-3 text-left font-semibold">Income Range</th>
                <th class="px-4 py-3 text-right font-semibold">Tax Rate</th>
                <th class="px-4 py-3 text-right font-semibold">Taxable Amount</th>
                <th class="px-4 py-3 text-right font-semibold">Tax Payable</th>
              </tr>
            </thead>
            <tbody>
              {bracketRows.map((row, i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-surface-alt"}>
                  <td class="px-4 py-3 text-text">{row.label}</td>
                  <td class="px-4 py-3 text-right font-medium text-primary">{row.rate}</td>
                  <td class="px-4 py-3 text-right">{fmtNZD(row.taxable)}</td>
                  <td class="px-4 py-3 text-right font-semibold text-secondary">{fmtNZD2(row.tax)}</td>
                </tr>
              ))}
              <tr class="bg-primary/5 font-bold">
                <td class="px-4 py-3 text-primary" colspan="3">Total PAYE</td>
                <td class="px-4 py-3 text-right text-primary">{fmtNZD2(baseResult.paye)}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </section>

  <!-- KiwiSaver Comparison Table -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2">
        KiwiSaver Impact on {entry.grossFormatted} Salary
      </h2>
      <p class="text-text-muted mb-6">
        See how different KiwiSaver contribution rates affect your take home pay at {entry.grossFormatted}.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-lg border border-border text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 text-left font-semibold">KiwiSaver Rate</th>
              <th class="px-4 py-3 text-right font-semibold">Employee Contribution</th>
              <th class="px-4 py-3 text-right font-semibold">Employer Contribution</th>
              <th class="px-4 py-3 text-right font-semibold">Total Deductions</th>
              <th class="px-4 py-3 text-right font-semibold">Net Annual</th>
              <th class="px-4 py-3 text-right font-semibold">Net Fortnightly</th>
            </tr>
          </thead>
          <tbody>
            {kiwiSaverComparison.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-surface-alt"}>
                <td class="px-4 py-3 font-semibold text-primary">
                  <a href={`/kiwisaver-${(row.rate * 100).toFixed(0)}-percent/`} class="hover:underline">
                    {row.rateLabel}
                  </a>
                </td>
                <td class="px-4 py-3 text-right text-secondary">{fmtNZD(row.employeeContribution)}</td>
                <td class="px-4 py-3 text-right text-text">{fmtNZD(row.employerContribution)}</td>
                <td class="px-4 py-3 text-right text-secondary">{fmtNZD(row.totalDeductions)}</td>
                <td class="px-4 py-3 text-right font-semibold text-green-600">{fmtNZD(row.netAnnual)}</td>
                <td class="px-4 py-3 text-right text-text">{fmtNZD2(row.netFortnightly)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- KiwiSaver Deep-Dive -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          KiwiSaver on a {entry.grossFormatted} Salary
        </h2>
        <p class="text-text leading-relaxed">{kiwiSaverDeepDive}</p>
      </article>
    </div>
  </section>

  <!-- Student Loan Section -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          Student Loan Repayments on {entry.grossFormatted}
        </h2>
        <p class="text-text leading-relaxed">{studentLoanSection}</p>
      </article>
    </div>
  </section>

  <!-- Monthly Budget Table -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
        Suggested Monthly Budget on {entry.grossFormatted}
      </h2>
      <p class="text-text-muted mb-6">
        Based on your net monthly income of {fmtNZD2(baseResult.netMonthly)} (with 3% KiwiSaver, no student loan), here is a suggested budget allocation following the principles of balanced household spending in New Zealand.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-lg border border-border text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 text-left font-semibold">Category</th>
              <th class="px-4 py-3 text-right font-semibold">%</th>
              <th class="px-4 py-3 text-right font-semibold">Monthly</th>
              <th class="px-4 py-3 text-left font-semibold hidden sm:table-cell">Note</th>
            </tr>
          </thead>
          <tbody>
            {budgetRows.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-surface-alt"}>
                <td class="px-4 py-3 text-text font-medium">{row.category}</td>
                <td class="px-4 py-3 text-right">{row.percentage}%</td>
                <td class="px-4 py-3 text-right font-semibold text-primary">{fmtNZD(row.monthly)}</td>
                <td class="px-4 py-3 text-text-muted text-xs hidden sm:table-cell">{row.note}</td>
              </tr>
            ))}
            <tr class="bg-primary/5 font-bold">
              <td class="px-4 py-3 text-primary">Total</td>
              <td class="px-4 py-3 text-right text-primary">100%</td>
              <td class="px-4 py-3 text-right text-primary">{fmtNZD(baseResult.netMonthly)}</td>
              <td class="px-4 py-3 hidden sm:table-cell"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Career Context -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          Career Outlook at {entry.grossFormatted} in New Zealand
        </h2>
        <p class="text-text leading-relaxed">{careerContext}</p>
      </article>
    </div>
  </section>

  <!-- Tax Optimisation Tips -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
        Tax Optimisation Tips for {entry.grossFormatted} Earners
      </h2>
      <p class="text-text-muted mb-6">
        Practical strategies to make the most of your {entry.grossFormatted} salary within the New Zealand tax system.
      </p>
      <div class="space-y-4">
        {taxTips.map((tip, i) => (
          <div class="bg-white rounded-xl border border-border shadow-sm p-5 flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
              <span class="text-primary font-bold text-sm">{i + 1}</span>
            </div>
            <p class="text-text leading-relaxed text-sm">{tip}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6">
        Frequently Asked Questions &mdash; {entry.grossFormatted} Salary in NZ
      </h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl border border-border shadow-sm group">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-primary hover:text-primary-light transition-colors list-none flex items-center justify-between">
              <span>{faq.question}</span>
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-text leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-primary mb-6">Explore Other Salary Levels</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {otherSalaries.map((s) => (
          <a
            href={`/salary-${s.slug}/`}
            class="bg-white rounded-lg border border-border p-4 text-center hover:border-primary hover:shadow-md transition-all"
