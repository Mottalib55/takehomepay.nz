---
import Layout from "../layouts/Layout.astro";
import SalaryCalculator from "../components/SalaryCalculator";
import { salaries, type SalaryEntry } from "../lib/salaries-data";
import { calculateSalary } from "../lib/engine";
import type { KiwiSaverRate } from "../lib/tax-rates-2026";
import "../styles/global.css";

export function getStaticPaths() {
  return salaries.map((entry) => ({
    params: { amount: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: SalaryEntry;
}

const { entry } = Astro.props;

// Calculate base result (3% KiwiSaver, no student loan, resident)
const baseResult = calculateSalary({
  annualGross: entry.gross,
  kiwiSaverRate: 0.03,
  hasStudentLoan: false,
  isResident: true,
});

// KiwiSaver comparison rates
const kiwiSaverRates: KiwiSaverRate[] = [0.03, 0.04, 0.06, 0.08, 0.10];
const kiwiSaverComparison = kiwiSaverRates.map((rate) => {
  const result = calculateSalary({
    annualGross: entry.gross,
    kiwiSaverRate: rate,
    hasStudentLoan: false,
    isResident: true,
  });
  return {
    rate,
    rateLabel: `${(rate * 100).toFixed(0)}%`,
    employeeContribution: result.kiwiSaverEmployee,
    employerContribution: result.kiwiSaverEmployer,
    totalDeductions: result.totalDeductions,
    netAnnual: result.netAnnual,
    netMonthly: result.netMonthly,
    netFortnightly: result.netFortnightly,
    netWeekly: result.netWeekly,
  };
});

const fmt = (n: number) =>
  new Intl.NumberFormat("en-NZ", {
    style: "currency",
    currency: "NZD",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(n);

const fmt2 = (n: number) =>
  new Intl.NumberFormat("en-NZ", {
    style: "currency",
    currency: "NZD",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(n);

const totalDeductions = baseResult.paye + baseResult.accLevy + baseResult.kiwiSaverEmployee;
const netPay = entry.gross - totalDeductions + baseResult.ietc;

const pageTitle = `${entry.grossFormatted} Salary in New Zealand - Take Home Pay 2026`;
const pageDescription = `Calculate your take home pay on a ${entry.grossFormatted} salary in New Zealand. See PAYE tax, ACC levy, KiwiSaver deductions, and net income for the 2025-2026 tax year.`;

// Cross-link data
const otherSalaries = salaries.filter((s) => s.slug !== entry.slug);

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://takehomepay.nz/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `${entry.grossFormatted} Salary`,
      item: `https://takehomepay.nz/salary-${entry.slug}/`,
    },
  ],
};

// Schema.org FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entry.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} canonical={`/salary-${entry.slug}/`}>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary via-primary-light to-accent py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/80">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="flex items-center gap-2">
            <span>/</span>
            <span class="text-white font-medium">{entry.grossFormatted} Salary</span>
          </li>
        </ol>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 text-white">
        {entry.grossFormatted} Salary in New Zealand
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-3xl">
        Take home pay breakdown for the 2025–2026 tax year with PAYE, ACC, and KiwiSaver.
      </p>
    </div>
  </section>

  <!-- Stat Cards -->
  <section class="py-8 sm:py-10 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Gross -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Gross Annual Salary</p>
          <p class="text-3xl font-bold text-primary">{entry.grossFormatted}</p>
          <p class="text-sm text-text-muted mt-1">{fmt2(baseResult.grossMonthly)}/month</p>
        </div>

        <!-- Deductions -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Total Deductions</p>
          <p class="text-3xl font-bold text-secondary">{fmt(baseResult.totalDeductions)}</p>
          <p class="text-sm text-text-muted mt-1">PAYE + ACC + KiwiSaver 3%</p>
        </div>

        <!-- Net -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Take Home Pay</p>
          <p class="text-3xl font-bold text-green-600">{fmt(baseResult.netAnnual)}</p>
          <p class="text-sm text-text-muted mt-1">{fmt2(baseResult.netFortnightly)}/fortnight</p>
        </div>
      </div>
    </div>
  </section>

  <!-- KiwiSaver Comparison Table -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2">
        KiwiSaver Impact on {entry.grossFormatted} Salary
      </h2>
      <p class="text-text-muted mb-6">
        See how different KiwiSaver contribution rates affect your take home pay at {entry.grossFormatted}.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-lg border border-border text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 text-left font-semibold">KiwiSaver Rate</th>
              <th class="px-4 py-3 text-right font-semibold">Employee Contribution</th>
              <th class="px-4 py-3 text-right font-semibold">Employer Contribution</th>
              <th class="px-4 py-3 text-right font-semibold">Total Deductions</th>
              <th class="px-4 py-3 text-right font-semibold">Net Annual</th>
              <th class="px-4 py-3 text-right font-semibold">Net Fortnightly</th>
            </tr>
          </thead>
          <tbody>
            {kiwiSaverComparison.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-surface-alt"}>
                <td class="px-4 py-3 font-semibold text-primary">
                  <a href={`/kiwisaver-${(row.rate * 100).toFixed(0)}-percent/`} class="hover:underline">
                    {row.rateLabel}
                  </a>
                </td>
                <td class="px-4 py-3 text-right text-secondary">{fmt(row.employeeContribution)}</td>
                <td class="px-4 py-3 text-right text-text">{fmt(row.employerContribution)}</td>
                <td class="px-4 py-3 text-right text-secondary">{fmt(row.totalDeductions)}</td>
                <td class="px-4 py-3 text-right font-semibold text-green-600">{fmt(row.netAnnual)}</td>
                <td class="px-4 py-3 text-right text-text">{fmt2(row.netFortnightly)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2 text-center">
        Calculate Your {entry.grossFormatted} Take Home Pay
      </h2>
      <p class="text-text-muted text-center mb-8">
        Adjust KiwiSaver rate, student loan, and residency settings to see your personalised breakdown.
      </p>
      <SalaryCalculator client:idle />
    </div>
  </section>

  <!-- Description Content -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          About a {entry.grossFormatted} Salary in New Zealand
        </h2>
        <p class="text-text leading-relaxed">{entry.description}</p>

        <h3 class="text-xl font-bold text-primary mt-8 mb-3">
          Detailed Breakdown at {entry.grossFormatted}
        </h3>
        <div class="bg-surface-alt rounded-xl p-6 space-y-3">
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">Gross Annual</span>
            <span class="font-semibold">{entry.grossFormatted}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">PAYE Income Tax</span>
            <span class="font-semibold text-secondary">-{fmt2(baseResult.paye)}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">ACC Earner's Levy (1.60%)</span>
            <span class="font-semibold text-secondary">-{fmt2(baseResult.accLevy)}</span>
          </div>
          <div class="flex justify-between border-b border-border pb-2">
            <span class="text-text-muted">KiwiSaver Employee (3%)</span>
            <span class="font-semibold text-secondary">-{fmt2(baseResult.kiwiSaverEmployee)}</span>
          </div>
          {baseResult.ietc > 0 && (
            <div class="flex justify-between border-b border-border pb-2">
              <span class="text-text-muted">IETC Credit</span>
              <span class="font-semibold text-green-600">+{fmt2(baseResult.ietc)}</span>
            </div>
          )}
          <div class="flex justify-between pt-2">
            <span class="font-bold text-primary">Take Home Pay</span>
            <span class="font-bold text-primary text-lg">{fmt2(baseResult.netAnnual)}</span>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6">
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Weekly</p>
            <p class="text-lg font-bold text-primary">{fmt2(baseResult.netWeekly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Fortnightly</p>
            <p class="text-lg font-bold text-primary">{fmt2(baseResult.netFortnightly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Monthly</p>
            <p class="text-lg font-bold text-primary">{fmt2(baseResult.netMonthly)}</p>
          </div>
          <div class="bg-white rounded-lg border border-border p-4 text-center">
            <p class="text-xs text-text-muted">Annual</p>
            <p class="text-lg font-bold text-primary">{fmt2(baseResult.netAnnual)}</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6">
        Frequently Asked Questions - {entry.grossFormatted} Salary
      </h2>
      <div class="space-y-4">
        {entry.faqs.map((faq) => (
          <details class="bg-white rounded-xl border border-border shadow-sm group">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-primary hover:text-primary-light transition-colors list-none flex items-center justify-between">
              <span>{faq.question}</span>
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-text leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-primary mb-6">Explore Other Salary Levels</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {otherSalaries.map((s) => (
          <a
            href={`/salary-${s.slug}/`}
            class="bg-white rounded-lg border border-border p-4 text-center hover:border-primary hover:shadow-md transition-all"
          >
            <span class="text-lg font-bold text-primary">{s.grossFormatted}</span>
            <span class="block text-xs text-text-muted mt-1">Salary</span>
          </a>
        ))}
      </div>

      <h3 class="text-xl font-bold text-primary mt-10 mb-4">KiwiSaver Contribution Guides</h3>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
        {[3, 4, 6, 8, 10].map((rate) => (
          <a
            href={`/kiwisaver-${rate}-percent/`}
            class="bg-white rounded-lg border border-border p-4 text-center hover:border-primary hover:shadow-md transition-all"
          >
            <span class="text-lg font-bold text-primary">{rate}%</span>
            <span class="block text-xs text-text-muted mt-1">KiwiSaver</span>
          </a>
        ))}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/" class="text-sm text-primary font-medium hover:underline">Salary Calculator</a>
        <span class="text-text-muted">|</span>
        <a href="/faq/" class="text-sm text-primary font-medium hover:underline">FAQ</a>
        <span class="text-text-muted">|</span>
        <a href="/legal/" class="text-sm text-primary font-medium hover:underline">Legal</a>
        <span class="text-text-muted">|</span>
        <a href="/privacy/" class="text-sm text-primary font-medium hover:underline">Privacy</a>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-6 bg-surface-alt border-t border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-text-muted text-center leading-relaxed">
        <strong>Disclaimer:</strong> This calculator provides estimates based on New Zealand tax rates for the 2025–2026 tax year (1 April 2025 – 31 March 2026). Results are for informational purposes only and should not be considered financial or tax advice. Individual circumstances may vary. For personalised advice, consult a qualified tax professional or visit the <a href="https://www.ird.govt.nz/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">IRD website</a>.
      </p>
    </div>
  </section>
</Layout>
