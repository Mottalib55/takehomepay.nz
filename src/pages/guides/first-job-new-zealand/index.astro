  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I get an IRD number in New Zealand?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can apply for an IRD number online through the IRD website (ird.govt.nz). You will need a valid form of identification such as a New Zealand passport, birth certificate, or visa. If you are a new migrant, you may need your passport and a letter from Immigration New Zealand confirming your visa status. The application is free and usually processed within 8-10 working days. You can also apply at an AA Driver Licensing agent or by post."
      }
    },
    {
      "@type": "Question",
      "name": "Do I have to join KiwiSaver in my first job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You do not strictly have to join, but you will be automatically enrolled by your employer when you start your first job (if you are aged 18 to 64 and employed for 28 days or more). You then have an opt-out window between day 14 and day 56 of employment. If you do not actively opt out, you remain a KiwiSaver member. Most financial advisors recommend staying in KiwiSaver because of the employer contribution (at least 3%) and the government contribution (up to $521.43 per year)."
      }
    },
    {
      "@type": "Question",
      "name": "What should I expect on my first payslip?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your first payslip will show your gross pay (total earnings before deductions) and then list each deduction: PAYE income tax, ACC Earner's Levy (1.60%), and KiwiSaver (at your chosen rate, default 3%). If you have a student loan, you will also see student loan repayments. The final figure is your net pay (take home pay), which is the amount deposited into your bank account. The difference between gross and net can be surprising at first, so use a salary calculator to estimate beforehand."
      }
    }
  ]
};
