---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

const guides = [
  {
    slug: "paye-tax-nz",
    icon: "💰",
    title: "PAYE Tax in New Zealand",
    description: "How the Pay As You Earn system works, the five tax brackets for 2025-2026, and how to calculate your income tax.",
  },
  {
    slug: "kiwisaver-guide",
    icon: "🏦",
    title: "KiwiSaver Guide",
    description: "Contribution rates, employer matching, fund types, and how KiwiSaver helps you save for retirement or your first home.",
  },
  {
    slug: "student-loan-repayment-nz",
    icon: "🎓",
    title: "Student Loan Repayment",
    description: "Repayment thresholds, the 12% deduction rate, interest-free rules, and what happens when you go overseas.",
  },
  {
    slug: "acc-levy",
    icon: "🛡️",
    title: "ACC Earner's Levy",
    description: "What the ACC levy is, the current rate, the earnings cap, and how it funds New Zealand's no-fault injury cover.",
  },
  {
    slug: "tax-codes-nz",
    icon: "🏷️",
    title: "NZ Tax Codes Explained",
    description: "A plain-English guide to M, ME, S, SH, ST, and student loan tax codes so you pick the right one every time.",
  },
  {
    slug: "secondary-income-tax",
    icon: "📋",
    title: "Secondary Income Tax",
    description: "How tax works when you have two or more jobs, which tax codes to use, and how to avoid an end-of-year bill.",
  },
  {
    slug: "first-job-new-zealand",
    icon: "🚀",
    title: "Starting Your First Job in NZ",
    description: "Everything a new worker needs: getting an IRD number, choosing a tax code, enrolling in KiwiSaver, and reading your payslip.",
  },
  {
    slug: "nz-vs-australia-salary",
    icon: "🌏",
    title: "NZ vs Australia Salary Comparison",
    description: "A side-by-side look at tax rates, superannuation, levies, and take home pay in New Zealand versus Australia.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://takehomepay.nz/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Guides",
      "item": "https://takehomepay.nz/guides/"
    }
  ]
};
---

<Layout
  title="Tax & Salary Guides for New Zealand Workers | TakeHomePay.nz"
  description="In-depth guides on PAYE tax, KiwiSaver, student loans, ACC levy, tax codes, secondary income, and more for New Zealand employees."
  canonical="/guides/"
>
  <!-- Schema.org BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-primary-light py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-white">New Zealand Tax & Salary Guides</h1>
      <p class="text-lg text-white/90">Plain-English guides to help you understand your pay, deductions, and entitlements in New Zealand.</p>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8 text-sm text-text-muted">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
          <li class="before:content-['/'] before:mx-2 before:text-border font-medium text-text">Guides</li>
        </ol>
      </nav>

      <!-- Guide Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {guides.map((guide) => (
          <a
            href={`/guides/${guide.slug}/`}
            class="group border border-border rounded-xl p-6 hover:shadow-lg hover:border-primary/30 transition-all duration-200 flex flex-col"
          >
            <span class="text-3xl mb-3" aria-hidden="true">{guide.icon}</span>
            <h2 class="text-lg font-bold text-primary mb-2 group-hover:text-accent transition-colors">{guide.title}</h2>
            <p class="text-sm text-text-muted leading-relaxed flex-1">{guide.description}</p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-4 group-hover:gap-2 transition-all">
              Read guide
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
