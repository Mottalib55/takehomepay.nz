---
import Layout from "../layouts/Layout.astro";
import SalaryCalculator from "../components/SalaryCalculator";
import { kiwiSaverRates, type KiwiSaverEntry } from "../lib/kiwisaver-data";
import { salaries } from "../lib/salaries-data";
import { calculateSalary } from "../lib/engine";
import type { KiwiSaverRate } from "../lib/tax-rates-2026";
import "../styles/global.css";

export function getStaticPaths() {
  return kiwiSaverRates.map((entry) => ({
    params: { rate: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: KiwiSaverEntry;
}

const { entry } = Astro.props;

// Comparison table: this KiwiSaver rate across all salary levels
const salaryComparison = salaries.map((salary) => {
  const result = calculateSalary({
    annualGross: salary.gross,
    kiwiSaverRate: entry.rateDecimal as KiwiSaverRate,
    hasStudentLoan: false,
    isResident: true,
  });
  const resultAt3 = calculateSalary({
    annualGross: salary.gross,
    kiwiSaverRate: 0.03,
    hasStudentLoan: false,
    isResident: true,
  });
  return {
    slug: salary.slug,
    grossFormatted: salary.grossFormatted,
    gross: salary.gross,
    employeeContribution: result.kiwiSaverEmployee,
    employerContribution: result.kiwiSaverEmployer,
    totalKiwiSaver: result.kiwiSaverEmployee + result.kiwiSaverEmployer,
    paye: result.paye,
    accLevy: result.accLevy,
    totalDeductions: result.totalDeductions,
    netAnnual: result.netAnnual,
    netFortnightly: result.netFortnightly,
    diffFrom3: result.netAnnual - resultAt3.netAnnual,
  };
});

const fmt = (n: number) =>
  new Intl.NumberFormat("en-NZ", {
    style: "currency",
    currency: "NZD",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(n);

const fmt2 = (n: number) =>
  new Intl.NumberFormat("en-NZ", {
    style: "currency",
    currency: "NZD",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(n);

const pageTitle = `KiwiSaver at ${entry.rate}% - Impact on Take Home Pay 2026`;
const pageDescription = `See how a ${entry.rate}% KiwiSaver contribution rate affects your take home pay in New Zealand. Compare across salary levels for the 2025-2026 tax year.`;

// Cross-link data
const otherRates = kiwiSaverRates.filter((r) => r.slug !== entry.slug);

// Projected savings example (30 years, 5% return, $70k salary)
const annualContribEmployee = 70000 * entry.rateDecimal;
const annualContribEmployer = 70000 * 0.03;
const annualContribTotal = annualContribEmployee + annualContribEmployer;
const projectedYears = 30;
const annualReturn = 0.05;
let projectedBalance = 0;
for (let y = 0; y < projectedYears; y++) {
  projectedBalance = (projectedBalance + annualContribTotal) * (1 + annualReturn);
}

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://takehomepay.nz/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `KiwiSaver ${entry.rate}%`,
      item: `https://takehomepay.nz/kiwisaver-${entry.slug}/`,
    },
  ],
};

// Schema.org FAQPage
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entry.faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} canonical={`/kiwisaver-${entry.slug}/`}>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary via-primary-light to-accent py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-white">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-white/80">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="flex items-center gap-2">
            <span>/</span>
            <span class="text-white font-medium">KiwiSaver {entry.rate}%</span>
          </li>
        </ol>
      </nav>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 text-white">
        KiwiSaver at {entry.rate}% - Take Home Pay Impact
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-3xl">
        How a {entry.rate}% KiwiSaver employee contribution affects your net income across salary levels in New Zealand for the 2025-2026 tax year.
      </p>
    </div>
  </section>

  <!-- Key Stats -->
  <section class="py-8 sm:py-10 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Employee Rate -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Employee Contribution</p>
          <p class="text-3xl font-bold text-primary">{entry.rate}%</p>
          <p class="text-sm text-text-muted mt-1">of gross salary</p>
        </div>

        <!-- Employer Match -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Employer Contribution</p>
          <p class="text-3xl font-bold text-green-600">3%</p>
          <p class="text-sm text-text-muted mt-1">minimum compulsory</p>
        </div>

        <!-- Projected Savings -->
        <div class="bg-white rounded-2xl shadow-lg border border-border p-6 text-center">
          <p class="text-sm font-medium text-text-muted mb-1">Projected Balance (30yr, $70k)</p>
          <p class="text-3xl font-bold text-accent">{fmt(Math.round(projectedBalance))}</p>
          <p class="text-sm text-text-muted mt-1">at 5% avg. annual return</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content About This Rate -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-4">
          Understanding the {entry.rate}% KiwiSaver Contribution Rate
        </h2>
        <p class="text-text leading-relaxed">{entry.description}</p>

        <h3 class="text-xl font-bold text-primary mt-8 mb-3">
          Employer Matching and Total Savings
        </h3>
        <p class="text-text leading-relaxed">
          When you contribute {entry.rate}% of your gross salary to KiwiSaver, your employer is required to contribute a minimum of 3% on top of your pay. This means a total of {entry.rate + 3}% of your gross salary flows into your KiwiSaver account each pay period. The employer contribution is subject to Employer Superannuation Contribution Tax (ESCT), which reduces the net amount slightly, but the overall benefit is significant. On a $70,000 salary, your combined annual KiwiSaver inflow would be {fmt(annualContribTotal)} before investment returns, comprising {fmt(annualContribEmployee)} from you and {fmt(annualContribEmployer)} from your employer.
        </p>

        <h3 class="text-xl font-bold text-primary mt-8 mb-3">
          Projected Retirement Savings
        </h3>
        <p class="text-text leading-relaxed">
          Based on a $70,000 salary with {entry.rate}% employee and 3% employer contributions, assuming consistent contributions over 30 years and an average annual investment return of 5%, your KiwiSaver balance could grow to approximately {fmt(Math.round(projectedBalance))}. This projection does not account for salary growth, inflation, government Member Tax Credits, or changes in contribution rates over time. Actual results will vary depending on market conditions and your chosen fund type (defensive, conservative, balanced, growth, or aggressive). Starting early and maintaining consistent contributions is the most powerful factor in building KiwiSaver wealth.
        </p>
      </article>
    </div>
  </section>

  <!-- Salary Comparison Table -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2">
        Take Home Pay at {entry.rate}% KiwiSaver - All Salary Levels
      </h2>
      <p class="text-text-muted mb-6">
        Comparison of take home pay with {entry.rate}% KiwiSaver across common NZ salary levels for the 2025-2026 tax year.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-lg border border-border text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 text-left font-semibold">Gross Salary</th>
              <th class="px-4 py-3 text-right font-semibold">Employee {entry.rate}%</th>
              <th class="px-4 py-3 text-right font-semibold">Employer 3%</th>
              <th class="px-4 py-3 text-right font-semibold">PAYE Tax</th>
              <th class="px-4 py-3 text-right font-semibold">Net Annual</th>
              <th class="px-4 py-3 text-right font-semibold">Net Fortnightly</th>
              {entry.rate !== 3 && (
                <th class="px-4 py-3 text-right font-semibold">vs 3% Rate</th>
              )}
            </tr>
          </thead>
          <tbody>
            {salaryComparison.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-surface-alt"}>
                <td class="px-4 py-3 font-semibold text-primary">
                  <a href={`/salary-${row.slug}/`} class="hover:underline">{row.grossFormatted}</a>
                </td>
                <td class="px-4 py-3 text-right text-secondary">{fmt(row.employeeContribution)}</td>
                <td class="px-4 py-3 text-right text-text">{fmt(row.employerContribution)}</td>
                <td class="px-4 py-3 text-right text-secondary">{fmt(row.paye)}</td>
                <td class="px-4 py-3 text-right font-semibold text-green-600">{fmt(row.netAnnual)}</td>
                <td class="px-4 py-3 text-right text-text">{fmt2(row.netFortnightly)}</td>
                {entry.rate !== 3 && (
                  <td class="px-4 py-3 text-right text-secondary font-medium">{fmt(row.diffFrom3)}</td>
                )}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-2 text-center">
        Calculate Your Take Home Pay at {entry.rate}% KiwiSaver
      </h2>
      <p class="text-text-muted text-center mb-8">
        Enter your salary and adjust settings to see your personalised breakdown.
      </p>
      <SalaryCalculator client:idle />
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-10 sm:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6">
        Frequently Asked Questions - KiwiSaver at {entry.rate}%
      </h2>
      <div class="space-y-4">
        {entry.faqs.map((faq) => (
          <details class="bg-white rounded-xl border border-border shadow-sm group">
            <summary class="px-6 py-4 cursor-pointer font-semibold text-primary hover:text-primary-light transition-colors list-none flex items-center justify-between">
              <span>{faq.question}</span>
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-text leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-primary mb-6">Other KiwiSaver Rates</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {otherRates.map((r) => (
          <a
            href={`/kiwisaver-${r.slug}/`}
            class="bg-white rounded-lg border border-border p-4 text-center hover:border-primary hover:shadow-md transition-all"
          >
            <span class="text-lg font-bold text-primary">{r.rate}%</span>
            <span class="block text-xs text-text-muted mt-1">KiwiSaver</span>
          </a>
        ))}
      </div>

      <h3 class="text-xl font-bold text-primary mt-10 mb-4">Explore Salary Levels</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {salaries.map((s) => (
          <a
            href={`/salary-${s.slug}/`}
            class="bg-white rounded-lg border border-border p-4 text-center hover:border-primary hover:shadow-md transition-all"
          >
            <span class="text-lg font-bold text-primary">{s.grossFormatted}</span>
            <span class="block text-xs text-text-muted mt-1">Salary</span>
          </a>
        ))}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/" class="text-sm text-primary font-medium hover:underline">Salary Calculator</a>
        <span class="text-text-muted">|</span>
        <a href="/faq/" class="text-sm text-primary font-medium hover:underline">FAQ</a>
        <span class="text-text-muted">|</span>
        <a href="/legal/" class="text-sm text-primary font-medium hover:underline">Legal</a>
        <span class="text-text-muted">|</span>
        <a href="/privacy/" class="text-sm text-primary font-medium hover:underline">Privacy</a>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-6 bg-surface-alt border-t border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-text-muted text-center leading-relaxed">
        <strong>Disclaimer:</strong> This page provides estimates based on New Zealand tax rates for the 2025-2026 tax year (1 April 2025 - 31 March 2026). Projected KiwiSaver balances are illustrative only and assume consistent contributions and returns. Actual investment returns will vary. Results are for informational purposes only and should not be considered financial or tax advice. For personalised advice, consult a qualified financial advisor or visit the <a href="https://www.kiwisaver.govt.nz/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">KiwiSaver website</a> or <a href="https://www.ird.govt.nz/" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">IRD website</a>.
      </p>
    </div>
  </section>
</Layout>
